    "http-proxy-middleware": "^2.0.6",
    "redis": "^4.6.10",
    "ioredis": "^5.3.2",
    "axios": "^1.6.2",
    "js-yaml": "^4.1.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
