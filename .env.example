# Server Configuration
PORT=8080
NODE_ENV=development

# Backend URLs (defaults to localhost for local dev; override for Docker/production)
USER_SERVICE_1_URL=http://localhost:3001
USER_SERVICE_2_URL=http://localhost:3002
USER_SERVICE_3_URL=http://localhost:3003
ORDER_SERVICE_1_URL=http://localhost:4001
ORDER_SERVICE_2_URL=http://localhost:4002
AUTH_SERVICE_1_URL=http://localhost:5001
AUTH_SERVICE_2_URL=http://localhost:5002

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=30000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# Health Check
HEALTH_CHECK_INTERVAL=10000
HEALTH_CHECK_TIMEOUT=5000

# Logging
LOG_LEVEL=info

# Metrics
METRICS_PORT=9090
